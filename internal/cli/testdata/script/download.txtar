# Successful download command shape uses the app boundary without prompts.
exec ghd download owner/repo/foo@1.2.3 --output out
stdout 'artifact out/artifact.tar.gz'
stdout 'verification out/verification.json'
stderr 'verified owner/repo/foo@1.2.3'
exists out/artifact.tar.gz
exists out/verification.json

# Malformed targets fail cleanly.
! exec ghd download foo --output out
stderr 'download target must be owner/repo/package@version'

# Help is scriptable and quiet on stderr.
exec ghd download --help
stdout 'Usage:'
stdout 'download owner/repo/package@version --output DIR'
! stderr .

# Successful install command shape uses explicit safe roots.
exec ghd install owner/repo/foo@1.2.3 --store-dir store --bin-dir bin
stdout 'binary bin/foo'
stderr 'installed owner/repo/foo@1.2.3'
exists bin/foo

# Malformed install targets fail cleanly.
! exec ghd install foo --store-dir store --bin-dir bin
stderr 'install target must be owner/repo/package@version'

# Install help is scriptable and quiet on stderr.
exec ghd install --help
stdout 'Usage:'
stdout 'install owner/repo/package@version --store-dir DIR --bin-dir DIR'
stdout '--store-dir'
stdout '--bin-dir'
! stderr .
