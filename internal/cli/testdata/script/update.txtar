# Successful update swaps the active install to the newer version.
exec ghd --state-dir state --yes --non-interactive install owner/repo/foo@1.2.3 --store-dir store --bin-dir bin
stderr 'installed owner/repo/foo@1\.2\.3'
exec ghd --state-dir state update foo --store-dir store --bin-dir bin
stdout 'owner/repo/foo 1\.2\.3 1\.3\.0 updated'
! stderr .
exec ghd --state-dir state installed
stdout 'owner/repo/foo 1\.3\.0 foo'
! exists store/github.com/owner/repo/foo/1.2.3/sha256-abc123
exists store/github.com/owner/repo/foo/1.3.0/sha256-abc123

# Already-current installs print an explicit no-op row.
exec ghd --state-dir current-state --yes --non-interactive install owner/repo/foo@1.3.0 --store-dir current-store --bin-dir current-bin
stderr 'installed owner/repo/foo@1\.3\.0'
exec ghd --state-dir current-state update foo --store-dir current-store --bin-dir current-bin
stdout 'owner/repo/foo 1\.3\.0 1\.3\.0 already-up-to-date'
! stderr .
exec ghd --state-dir current-state update foo --json --store-dir current-store --bin-dir current-bin
stdout '"updates":\['
stdout '"repository":"owner/repo"'
stdout '"package":"foo"'
stdout '"target":"owner/repo/foo"'
stdout '"previous_version":"1\.3\.0"'
stdout '"current_version":"1\.3\.0"'
stdout '"status":"already-up-to-date"'
! stderr .

# Updates refuse binary names already owned by another installed package.
! exec ghd --state-dir collision-state update owner/repo/foo --store-dir collision-store --bin-dir collision-bin
stdout 'owner/repo/foo 1\.2\.3 1\.2\.3 cannot-update binary "foo" is already owned by owner/other/bar'
stderr 'could not update 1 installed package'
! exists collision-store

# Ambiguous update targets require qualification.
! exec ghd --state-dir ambiguous-state update foo --store-dir store --bin-dir bin
stderr 'installed package "foo" is ambiguous'
stderr 'owner/one/foo'
stderr 'owner/two/bar'

# Plain failures do not print result rows first.
! exec ghd --state-dir empty-state update foo --store-dir store --bin-dir bin
stderr 'package "foo" is not installed'
! stdout .

# Batch update prints every row, then returns an aggregate error.
! exec ghd --state-dir batch-state update --all --store-dir batch-store --bin-dir batch-bin
stdout 'owner/broken/broken 1\.2\.3 1\.2\.3 cannot-update fetch ghd\.toml: missing'
stdout 'owner/current/current 1\.3\.0 1\.3\.0 already-up-to-date'
stdout 'owner/repo/foo 1\.2\.3 1\.3\.0 updated'
stdout 'owner/warn/warn 1\.2\.3 1\.3\.0 updated-with-warning updated owner/warn/warn@1\.2\.3 -> 1\.3\.0 but failed to remove previous store: permission denied'
stderr 'update completed with 1 warning and 1 failure'
exec ghd --state-dir batch-state installed
stdout 'owner/broken/broken 1\.2\.3 broken'
stdout 'owner/current/current 1\.3\.0 current'
stdout 'owner/repo/foo 1\.3\.0 foo'
stdout 'owner/warn/warn 1\.3\.0 warn'

# Missing targets fail cleanly.
! exec ghd update --store-dir store --bin-dir bin
stderr 'update target must be set'

# Missing targets fail before runtime setup.
! exec ghd --trusted-root /tmp/ghd-missing-trusted-root update --store-dir store --bin-dir bin
stderr 'update target must be set'
! stderr 'trusted-root'

# Target and --all cannot be combined.
! exec ghd update foo --all --store-dir store --bin-dir bin
stderr 'update accepts a target or --all, not both'

# Malformed targets fail cleanly.
! exec ghd update owner/repo --store-dir store --bin-dir bin
stderr 'update target must be name or owner/repo/package'

# Help is scriptable and quiet on stderr.
exec ghd update --help
stdout 'Usage:'
stdout 'update \[name\|owner/repo/package\|--all\] --store-dir DIR --bin-dir DIR'
stdout '--all'
stdout '--store-dir'
stdout '--bin-dir'
! stderr .

