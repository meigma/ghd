# Repository commands persist a local index.
exec ghd --index-dir index repo add owner/repo
stderr 'indexed owner/repo'
exec ghd --index-dir index repo list
stdout 'owner/repo foo'
exec ghd --index-dir index repo list --json
stdout '"repositories":\['
stdout '"repository":"owner/repo"'
stdout '"packages":\[\{"name":"foo"'
stdout '"binaries":\["foo"\]'
stdout '"refreshed_at":"'
! stderr .

# Refresh can target one repository.
exec ghd --index-dir index repo refresh owner/repo
stderr 'refreshed owner/repo'

# Unqualified versionless install resolves through the local index and picks the latest stable release.
exec ghd --index-dir index --state-dir state --yes --non-interactive install foo --store-dir store --bin-dir bin
stdout 'binary .*/bin/foo'
stderr 'installed owner/repo/foo@1.3.0'
exists bin/foo
exec ghd --state-dir state installed
stdout 'owner/repo/foo 1.3.0 foo'
exec ghd --state-dir state installed --json
stdout '"installed":\['
stdout '"repository":"owner/repo"'
stdout '"package":"foo"'
stdout '"target":"owner/repo/foo"'
stdout '"version":"1.3.0"'
stdout '"binaries":\[\{"name":"foo"'
! stderr .

# Remove only updates the local index.
exec ghd --index-dir index repo remove owner/repo
stderr 'removed owner/repo'
exec ghd --index-dir index repo list
! stdout 'owner/repo'

# Ambiguous unqualified installs require repository qualification.
exec ghd --index-dir ambiguous repo add owner/one
exec ghd --index-dir ambiguous repo add owner/two
! exec ghd --index-dir ambiguous --state-dir ambiguous-state install foo --store-dir other-store --bin-dir other-bin
stderr 'package "foo" is ambiguous'
stderr 'owner/one'
stderr 'owner/two'

# Exact package-name matches win over exposed binary-name matches.
exec ghd --index-dir binary-ambiguous repo add owner/repo
exec ghd --index-dir binary-ambiguous repo add owner/binary
exec ghd --index-dir binary-ambiguous --state-dir binary-state --yes --non-interactive install foo --store-dir binary-store --bin-dir binary-bin
stdout 'binary .*/binary-bin/foo'
stderr 'installed owner/repo/foo@1.3.0'
exists binary-bin/foo
exec ghd --state-dir binary-state installed
stdout 'owner/repo/foo 1.3.0 foo'

# Unqualified install refreshes indexed repositories before resolution.
mkdir stale-ambiguous
cp stale-ambiguous-index.json stale-ambiguous/repositories.json
! exec ghd --index-dir stale-ambiguous --state-dir stale-state install foo --store-dir stale-store --bin-dir stale-bin
stderr 'package "foo" is ambiguous'
stderr 'owner/one/foo'
stderr 'owner/two/foo'

# Repo help is scriptable and quiet on stderr.
exec ghd repo --help
stdout 'Available Commands:'
stdout 'add'
stdout 'list'
stdout 'remove'
stdout 'refresh'
stdout 'Examples:'
stdout 'ghd repo add owner/repo --index-dir ./index'
stdout 'ghd repo refresh --index-dir ./index --all'
! stderr .

exec ghd repo add --help
stdout 'ghd repo add owner/repo --index-dir ./index'
! stderr .

exec ghd repo refresh --help
stdout 'ghd repo refresh owner/repo --index-dir ./index'
stdout 'ghd --non-interactive repo refresh --index-dir ./index --all'
! stderr .

-- stale-ambiguous-index.json --
{
  "schema_version": 1,
  "repositories": [
    {
      "repository": {
        "Owner": "owner",
        "Name": "one"
      },
      "packages": [
        {
          "name": "foo"
        }
      ],
      "refreshed_at": "2026-04-22T00:00:00Z"
    },
    {
      "repository": {
        "Owner": "owner",
        "Name": "two"
      },
      "packages": [
        {
          "name": "bar"
        }
      ],
      "refreshed_at": "2026-04-22T00:00:00Z"
    }
  ]
}
